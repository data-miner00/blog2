---
layout: home.liquid
lang: en
title: Posts - Shaun Chong
---
<h2 class="font-bold mb-5">Posts</h2>

<ul class="flex flex-col gap-2">
  {% assign recentPosts = collections.post | reverse %}
  {% for item in recentPosts %}
    <li class="block">
      <a class="nonchalant flex justify-between items-center" href="{{ item.url }}">
        <span class="block">{{ item.data.title }}</span>
        <span class="block text-gray-500">{{ item.data.date | dayMonth }}</span>
      </a>
    </li>
  {% else %}
    <li>The collection is empty.</li>
  {% endfor %}
</ul>
